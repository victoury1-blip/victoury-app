{
  "functions": {
    "api/ozone-check.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/ozone-client/:path*", "destination": "https://client.ozoneexpress.ma/:path*" },
    { "source": "/ozone-api/:path*", "destination": "https://api.ozonexpress.ma/:path*" },
    { "source": "/wc-api/:path*", "destination": "https://victoury-maroc.com/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
